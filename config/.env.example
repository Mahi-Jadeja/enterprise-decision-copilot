# ============================================
# SUPABASE DATABASE CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================

# Supabase Project URL
# Found in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key
# Found in: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (for admin operations)
# Found in: Supabase Dashboard → Settings → API → service_role
# ⚠️ Keep this secret! Never expose in frontend code
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================
# DIRECT DATABASE CONNECTION
# ============================================
# For Python scripts using psycopg2/sqlalchemy
# Found in: Supabase Dashboard → Settings → Database → Connection string

# Database Host
# Format: db.your-project-id.supabase.co
DB_HOST=db.your-project-id.supabase.co

# Database Port (default: 5432)
DB_PORT=5432

# Database Name (default: postgres)
DB_NAME=postgres

# Database User (default: postgres)
DB_USER=postgres

# Database Password
# Found in: Supabase Dashboard → Settings → Database → Database password
DB_PASSWORD=your-database-password-here

# Full Database URL (alternative to individual params)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ============================================
# DATA GENERATION SETTINGS
# ============================================
# Control the size of generated dataset

# Number of customers to generate
CUSTOMERS_COUNT=1000

# Number of sellers to generate
SELLERS_COUNT=150

# Number of products to generate
PRODUCTS_COUNT=2000

# Number of warehouses to generate
WAREHOUSES_COUNT=10

# Number of orders to generate
ORDERS_COUNT=8000

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Random seed for reproducible data generation
# Set to any integer for consistent results across runs
RANDOM_SEED=42

# Batch size for database inserts
# Lower value = slower but safer for free tier
BATCH_SIZE=500

# Enable verbose logging (true/false)
VERBOSE=true

# ============================================
# NOTES FOR SUPABASE SETUP
# ============================================
# 
# 1. Create a free Supabase account at https://supabase.com
# 
# 2. Create a new project (remember your database password!)
# 
# 3. Go to Settings → Database to find connection details
# 
# 4. Go to Settings → API to find API keys
# 
# 5. The free tier limits:
#    - 500 MB database size
#    - 2 GB bandwidth per month
#    - 50,000 monthly active users
#    - Our ~90k rows dataset fits comfortably!
#
# ============================================